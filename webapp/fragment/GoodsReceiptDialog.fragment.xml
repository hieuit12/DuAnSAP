<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">
    <Dialog id="goodsReceiptDialog" title="{i18n>dialogGoodsReceipt}">
        <content>
            <f:SimpleForm editable="true" layout="ResponsiveGridLayout">
                <f:content>
                    <Label text="{i18n>materialId}" required="true" />
                    <Input value="{formModel>/goodsReceiptForm/MaterialId}" />
                    
                    <Label text="{i18n>plant}" required="true" />
                    <ComboBox id="grPlantComboBox" items="{/PlantMasterSet}" selectedKey="{formModel>/goodsReceiptForm/Plant}" selectionChange="onChangePlant">
                        <core:Item key="{PlantId}" text="{PlantId} - {PlantName}" />
                    </ComboBox>
                    
                    <Label text="{i18n>storageLocation}" required="true" />
                    <ComboBox id="grSLocComboBox" 
                        items="{path: '/StorageLocationMasterSet'}"
                        selectedKey="{formModel>/goodsReceiptForm/StorageLocation}">
                        <core:Item key="{StorageLocationId}" text="{StorageLocationId} - {StorageLocationName}" />
                    </ComboBox>
                    
                    <Label text="{i18n>quantity}" required="true" />
                    <StepInput value="{formModel>/goodsReceiptForm/Quantity}" min="0.001" step="1" />
                    
                    <Label text="Ngày hạch toán" />
                    <DatePicker value="{path: 'formModel>/goodsReceiptForm/PostingDate', type: 'sap.ui.model.type.Date', formatOptions: { pattern: 'yyyy-MM-dd' }}" />
                    
                    <Label text="Ngày chứng từ" />
                    <DatePicker value="{path: 'formModel>/goodsReceiptForm/DocumentDate', type: 'sap.ui.model.type.Date', formatOptions: { pattern: 'yyyy-MM-dd' }}" />
                    
                    <Label text="Ghi chú" />
                    <TextArea value="{formModel>/goodsReceiptForm/Remark}" rows="2" />
                </f:content>
            </f:SimpleForm>
        </content>
        <beginButton>
            <Button text="{i18n>btnPost}" type="Emphasized" press="onConfirmGoodsReceipt" />
        </beginButton>
        <endButton>
            <Button text="{i18n>btnCancel}" press="onCancelGoodsReceipt" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
