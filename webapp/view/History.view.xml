<mvc:View controllerName="com.sap341.smartwarehouse.controller.History"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core">
    <Page title="Transaction History" showHeader="true">
        <headerContent>
            <Button icon="sap-icon://refresh" press="onRefresh" />
        </headerContent>
        <content>
            <VBox class="sapUiSmallMargin">
                <fb:FilterBar id="filterBar" Header="Search" reset="onReset" search="onSearch" showRestoreButton="true" showClearButton="true" xmlns:fb="sap.ui.comp.filterbar">
                    <fb:filterGroupItems>
                        <fb:FilterGroupItem name="MaterialId" label="Material" groupName="Main" visibleInFilterBar="true">
                            <fb:control>
                                <Input id="filterMaterial" placeholder="Enter Material ID..." />
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem name="Plant" label="Plant" groupName="Main" visibleInFilterBar="true">
                            <fb:control>
                                <ComboBox id="filterPlant" items="{path: '/PlantMasterSet'}" selectionChange="onPlantChange">
                                    <core:Item xmlns:core="sap.ui.core" key="{PlantId}" text="{PlantId} - {PlantName}" />
                                </ComboBox>
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem name="StorageLocation" label="Location" groupName="Main" visibleInFilterBar="true">
                            <fb:control>
                                <ComboBox id="filterStorageLocation" items="{path: '/StorageLocationMasterSet'}">
                                    <core:Item key="{StorageLocationId}" text="{StorageLocationId} - {StorageLocationName}" />
                                </ComboBox>
                            </fb:control>
                        </fb:FilterGroupItem>
                    </fb:filterGroupItems>
                </fb:FilterBar>

                <Table id="historyTable" items="{path: '/HistorySet', sorter: {path: 'PostingDate', descending: true}}" growing="true" growingThreshold="50" class="sapUiMediumMarginTop">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="Recent Transactions" level="H3" />
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column width="120px"><Text text="Document" /></Column>
                        <Column width="80px"><Text text="Year" /></Column>
                        <Column><Text text="Posting Date" /></Column>
                        <Column><Text text="Material" /></Column>
                        <Column width="80px"><Text text="Move Type" /></Column>
                        <Column hAlign="End"><Text text="Quantity" /></Column>
                        <Column width="60px"><Text text="UoM" /></Column>
                        <Column><Text text="Plant/SLoc" /></Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <ObjectIdentifier title="{MaterialDocument}" />
                                <Text text="{Year}" />
                                <Text text="{path: 'PostingDate', type: 'sap.ui.model.type.Date', formatOptions: { pattern: 'dd/MM/yyyy' }}" />
                                <Text text="{MaterialId}" />
                                <Text text="{MovementType}" />
                                <ObjectNumber number="{parts: [{path: 'Quantity'}, {path: 'MovementType'}], formatter: '.formatter.quantityText'}" 
                                              state="{path: 'MovementType', formatter: '.formatter.movementState'}" />
                                <Text text="{BaseUnit}" />
                                <Text text="{Plant}/{StorageLocation}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
